{
  "manifest_version": 2,
  "name": "EQ Pro",
  "version": "1.0.0",
  "description": "Simple sound booster + equalizer with presets. Doesn't break DRM streaming like other boosters do.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "webNavigation",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "EQ Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "eqpro@slopcodebutworking"
    }
  }
}